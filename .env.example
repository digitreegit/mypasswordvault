# Browser (Vite) — required for sign-in, cloud sync, and Stripe checkout
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Local Stripe embedded checkout (pk_test_… from Stripe Dashboard → Developers → API keys)
# Optional if create-checkout-session returns publishable_key from Supabase STRIPE_PUBLISHABLE_KEY secret.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets, or `supabase secrets set`)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PUBLIC_APP_URL=https://mypasswordvault.app/app
# STRIPE_LICENSE_AMOUNT_CENTS=499
# ADMIN_EMAILS=you@company.com,ops@company.com   # admin-api + /app/#/admin dashboard
