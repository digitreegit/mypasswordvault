# Copy to .env (local dev) or set in Vercel → Project → Settings → Environment Variables.
# Required for Google sign-in and cloud vault sync. Rebuild/redeploy after changing values.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# iOS/Android (Capacitor): add this Redirect URL in Supabase → Authentication → URL configuration:
#   com.skyface.mypasswordvault://auth/callback
