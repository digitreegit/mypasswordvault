# Copy to .env (local dev) or set in Vercel → Project → Settings → Environment Variables.
# Required for Google sign-in and cloud vault sync. Rebuild/redeploy after changing values.

# Default: *.supabase.co — Google OAuth shows "continue to YOUR_REF.supabase.co".
# After Supabase Custom Domain (see docs/google-oauth-domain.md), point at your API host, e.g.:
# VITE_SUPABASE_URL=https://auth.mypasswordvault.app
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# iOS/Android (Capacitor): add this Redirect URL in Supabase → Authentication → URL configuration:
#   com.skyface.mypasswordvault://auth/callback
