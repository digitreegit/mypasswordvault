{
  "name": "mypasswordapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/postbuild.mjs",
    "build:capacitor": "tsc -b && vite build --config vite.capacitor.config.ts && node scripts/capacitor-postbuild.mjs",
    "cap:sync": "npm run build:capacitor && npx cap sync && node scripts/patch-ios-url-scheme.mjs",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:run:ios": "npm run cap:sync && npx cap run ios",
    "preview": "vite preview",
    "landing:assemble": "node scripts/assemble-landing-pages.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.1",
    "@capacitor/browser": "^7.0.1",
    "@capacitor/core": "^7.0.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@heroicons/react": "^2.2.0",
    "@passwordless-id/webauthn": "^2.4.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@supabase/supabase-js": "^2.105.4",
    "idb": "^8.0.0",
    "otpauth": "^9.3.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.1",
    "@capacitor/ios": "^7.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
